# ============================================================================
# Claude LiteLLM Proxy - Environment Configuration
# ============================================================================
#
# For Portainer deployment:
# 1. Copy this file and save as .env on your local machine
# 2. Customize values below for your network
# 3. Upload in Portainer: Stacks → Add stack → Load variables from .env file
#
# For docker-compose deployment:
# 1. Copy this file: cp .env.example .env
# 2. Edit values: nano .env
# 3. Deploy: docker-compose up -d
# ============================================================================

# ============================================================================
# CONTAINER SETTINGS
# ============================================================================

# Username for SSH access to the container
# Default: litellm (no need to change unless you have naming conflicts)
USERNAME=litellm

# Password for SSH login (IMPORTANT: Change this!)
# This is used for: ssh litellm@CONTAINER_IP
# ⚠️ Security: Use a strong password - this will be exposed on your network
USER_PASSWORD=changeme123

# Docker container name
# Shows up in: docker ps, Portainer container list
CONTAINER_NAME=litellm-proxy

# Container hostname (internal DNS name)
HOSTNAME=litellm-proxy

# Static IP address for the container on your network
# ⚠️ IMPORTANT:
# - Must be an available IP on your network
# - Should be OUTSIDE your DHCP range to avoid conflicts
# - Example: If your network is 192.168.111.0/24 and DHCP uses .100+,
#   you can use .15, .16, .17, etc. (below DHCP range)
# - This is the IP you'll use to connect: http://CONTAINER_IP:4000
CONTAINER_IP=192.168.111.15

# ============================================================================
# NETWORK SETTINGS (Macvlan)
# ============================================================================
# These settings allow the container to get a direct IP on your network.
# To find your values, run on your Docker host:
#   ip addr show              (find NETWORK_INTERFACE)
#   ip route | grep default   (find NETWORK_GATEWAY)
# ============================================================================

# Network interface on your Docker host
# Common values: eth0, ens33, ens192, enp0s3
# Run: ip addr show (to find yours)
NETWORK_INTERFACE=eth0

# Your network subnet in CIDR notation
# Examples:
#   192.168.111.0/24  (covers 192.168.111.1 - 192.168.111.254)
#   192.168.1.0/24    (covers 192.168.1.1 - 192.168.1.254)
#   192.168.0.0/24    (covers 192.168.0.1 - 192.168.0.254)
#   10.0.0.0/24       (covers 10.0.0.1 - 10.0.0.254)
NETWORK_SUBNET=192.168.111.0/24

# Your network gateway (usually your router IP)
# Common values: 192.168.111.254, 192.168.1.1, 192.168.0.1, 10.0.0.1
# Run: ip route | grep default (to find yours)
NETWORK_GATEWAY=192.168.111.254

# IP range for this Docker network (must include CONTAINER_IP)
# Use /32 for a single IP, or /29 for multiple containers (8 IPs)
# Examples:
#   192.168.111.15/32  (single IP - just .15)
#   192.168.111.8/29   (covers .8-.15, 8 IPs)
#   192.168.111.16/29  (covers .16-.23, 8 IPs)
# Make sure this range:
#   - Is within NETWORK_SUBNET
#   - Includes CONTAINER_IP
#   - Doesn't overlap with DHCP range
NETWORK_IP_RANGE=192.168.111.15/32

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================

# Container timezone (affects logs and timestamps)
# Examples:
#   America/New_York
#   America/Los_Angeles
#   Europe/London
#   UTC (default)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC

# ============================================================================
# NOTES
# ============================================================================
#
# Google API Key Configuration:
# - The Google API key is NOT set here (too sensitive)
# - After deployment, SSH to the container and edit:
#   ~/.config/litellm/.env
# - Get your key from: https://aistudio.google.com/app/apikey
#
# Security Tips:
# - Never commit .env to version control (.gitignore blocks this)
# - Use a strong USER_PASSWORD
# - Firewall port 4000 to only allow trusted IPs
# - Set up SSH keys and disable password authentication
#
# Troubleshooting:
# - If container won't start: check CONTAINER_IP isn't already in use
# - If can't connect: verify NETWORK_SUBNET and NETWORK_GATEWAY match your network
# - If macvlan fails: your Docker host may not support it, use bridge mode instead
#   (see PORTAINER.md for bridge networking instructions)
#
# ============================================================================
