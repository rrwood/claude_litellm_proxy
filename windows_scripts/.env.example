# .env — Claude Code environment configuration
# Place this file in your working project directory, or alongside Start-Claude.ps1
# Copy this file to .env and fill in your values.

# LiteLLM proxy endpoint (replaces the Anthropic API)
ANTHROPIC_BASE_URL=http://YOUR_CONTAINER_IP:4000
ANTHROPIC_API_KEY=DUMMY_KEY

# Nvidia NIM (used by LiteLLM, not Claude Code directly)
# NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# Google AI (optional, if routing Gemini through LiteLLM)
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx