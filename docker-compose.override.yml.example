# Example: Use existing macvlan network instead of auto-creating
#
# If you already have a macvlan-for-direct-access network created manually,
# you can use this override to tell Docker Compose to use the existing network.
#
# To use:
# 1. Copy this file: cp docker-compose.override.yml.example docker-compose.override.yml
# 2. Deploy normally: docker-compose up -d
#
# Docker Compose will automatically merge the override with docker-compose.yml,
# using the external network instead of creating a new one.

networks:
  macvlan-for-direct-access:
    external: true
